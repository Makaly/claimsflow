/// Normalised aliases for provider names extracted by OCR.
/// One row per alias variant → canonical provider. Allows the
/// mismatch fraud signal to survive spelling differences and
/// abbreviations without false positives.
model ProviderAlias {
  id         String   @id @default(uuid())
  providerId String
  alias      String   @unique // normalised: lowercase, no punctuation, collapsed spaces
  createdAt  DateTime @default(now())
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@map("provider_aliases")
}

/// Records every OCR zone extraction attempt — the knowledge base for
/// zone accuracy analytics. One row per zone × document extraction.
/// When a reviewer corrects a field value, wasCorrect is set to false
/// and correctedValue captures what the field should have been, creating
/// a supervised training signal for future zone refinement.
model OcrZoneHit {
  id             String       @id @default(uuid())
  zoneId         String
  templateId     String
  claimId        String?
  documentId     String?
  fieldName      String // e.g. "invoice_amount"
  fieldLabel     String // e.g. "Invoice Amount"
  extractedValue String?
  confidence     Float? // 0–1
  engine         String? // "gemini" | "anthropic" | "tesseract"
  wasCorrect     Boolean? // null = unverified; true = confirmed correct; false = corrected
  correctedValue String? // what the user set it to
  correctedBy    String? // userId
  correctedAt    DateTime?
  createdAt      DateTime     @default(now())
  zone           DocumentZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  template       OcrTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([zoneId])
  @@index([templateId])
  @@index([claimId])
  @@index([fieldName])
  @@index([createdAt])
  @@map("ocr_zone_hits")
}

/// Per-line-item extraction from an invoice.
/// Each row represents one billed service, drug, or procedure extracted
/// from the invoice table via layout-aware OCR or a vision model.
model InvoiceLineItem {
  id                 String   @id @default(uuid())
  claimId            String
  lineNumber         Int?
  description        String
  itemName           String?
  category           String?
  quantity           Float?
  unitPrice          Float?
  totalPrice         Float?
  taxAmount          Float?
  discount           Float?
  currency           String   @default("KES")
  serviceDate        String?
  procedureCode      String?
  // Confidence scores (0-1)
  ocrConfidence      Float?
  layoutConfidence   Float?
  semanticConfidence Float?
  overallConfidence  Float?
  // Fraud detection
  fraudRisk          String? // "low" | "medium" | "high"
  fraudRiskScore     Float? // 0-1
  fraudFlags         String[]
  arithmeticValid    Boolean? // qty × unitPrice ≈ totalPrice
  rawText            String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  claim              Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId])
  @@index([fraudRisk])
  @@map("invoice_line_items")
}

