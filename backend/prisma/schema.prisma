// ─── C5: Swahili locale on User ──────────────────────────────────────────────

// locale field added to User below via migration; stored in users.locale (String?)

/// Append-only log of every scan attempted from a logged-in session.
/// `deviceClass` distinguishes physical-scanner desktops from mobile/camera
/// captures so dashboards can break down usage by channel.
model ScanEvent {
  id              String   @id @default(uuid())
  userId          String
  providerId      String?
  branchId        String?
  deviceClass     String // 'desktop' | 'mobile' | 'camera'
  os              String? // 'linux' | 'windows' | 'darwin' | 'android' | 'ios' | 'web'
  machineHostname String?
  userAgent       String?
  scannerName     String?
  resolution      Int?
  mode            String?
  pages           Int?
  costAtScan      Decimal  @default(0) @db.Decimal(10, 2)
  currency        String   @default("KES")
  success         Boolean  @default(true)
  errorMessage    String?
  createdAt       DateTime @default(now())

  user     User      @relation("ScanEventUser", fields: [userId], references: [id], onDelete: Cascade)
  provider Provider? @relation("ScanEventProvider", fields: [providerId], references: [id], onDelete: SetNull)
  branch   Branch?   @relation("ScanEventBranch", fields: [branchId], references: [id], onDelete: SetNull)

  @@index([providerId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("scan_events")
}

/// T2.4 — Configurable cross-provider duplicate-detection lookback window per
/// claim type. pharmacy duplicates surface in days; inpatient duplicates can
/// surface weeks or months later. claimType is a free-form string ('pharmacy',
/// 'outpatient', 'inpatient', 'dental', 'optical', ...) and falls back to the
/// row keyed 'default' when no specific row matches.
model ClaimTypeConfig {
  id         String   @id @default(uuid())
  claimType  String   @unique
  windowDays Int
  updatedBy  String?
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@index([claimType])
  @@map("claim_type_config")
}

/// T2.2 — Per-provider fraud decision threshold, recomputed monthly.
model ProviderFraudThreshold {
  id           String    @id @default(uuid())
  providerId   String    @unique
  threshold    Float
  fpRate       Float
  fnRate       Float
  computedAt   DateTime  @default(now())
  overriddenBy String?
  overriddenAt DateTime?
  provider     Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@index([computedAt])
  @@map("provider_fraud_thresholds")
}

/// T3.5 — Pacing alerts for scan-metering quota.
model ScanPacingAlert {
  id           String    @id @default(uuid())
  providerId   String
  dayOfMonth   Int
  usedPct      Decimal   @db.Decimal(5, 2)
  projectedDay Int?
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId, createdAt(sort: Desc)])
  @@index([resolvedAt])
  @@map("scan_pacing_alerts")
}

