// ─── D4: Chronic-disease cohort tracking ─────────────────────────────────────

model ChronicCondition {
  id             String   @id @default(uuid())
  code           String   @unique
  name           String
  qualifyingRule Json // {icd10Prefixes: string[], minEncounters: int, withinDays: int}
  createdAt      DateTime @default(now())

  memberStatuses MemberChronicStatus[]

  @@map("chronic_conditions")
}

model MemberChronicStatus {
  id              String           @id @default(uuid())
  memberNumber    String
  conditionCode   String
  confidence      Float            @default(1.0)
  firstObservedAt DateTime         @default(now())
  lastObservedAt  DateTime         @default(now())
  status          String           @default("active") // "active"|"resolved"|"suspected"
  condition       ChronicCondition @relation(fields: [conditionCode], references: [code])

  @@unique([memberNumber, conditionCode])
  @@index([memberNumber])
  @@index([conditionCode])
  @@index([status])
  @@map("member_chronic_statuses")
