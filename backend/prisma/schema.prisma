generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String                  @id @default(uuid())
  email                 String                  @unique
  password              String
  name                  String
  role                  String                  @default("user")
  isActive              Boolean                 @default(true)
  requirePasswordChange Boolean                 @default(false)
  lastLogin             DateTime?
  failedLoginAttempts   Int                     @default(0)
  lockedUntil           DateTime?
  twoFactorEnabled      Boolean                 @default(false)
  twoFactorSecret       String?
  phone                 String?
  jobTitle              String?
  department            String?
  location              String?
  timezone              String?
  language              String?
  bio                   String?
  avatarUrl             String?
  savedSignatures       Json?                   @default("[]")
  providerId            String?
  branchId              String?
  passwordResetToken    String?
  passwordResetExpiry   DateTime?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  createdBy             String?
  updatedBy             String?
  // GDPR Art. 17 — soft-erasure marker. When set, login is blocked and PII
  // is replaced with anonymised tokens but referential integrity for legally
  // retained claim records (Insurance Act 2017 s.83 — 7 year retention) is
  // preserved.
  deletedAt             DateTime?
  activityLogs          ActivityLog[]
  claimsApproved        ClaimApproval[]
  claimsAssigned        Claim[]                 @relation("ClaimAssignee")
  claimsCreated         Claim[]                 @relation("ClaimCreator")
  notifications         Notification[]
  userRoles             UserRole[]
  provider              Provider?               @relation(fields: [providerId], references: [id])
  appeals               Appeal[]                @relation("AppealAdjudicator")
  appealsFiled          Appeal[]                @relation("AppealFiler")
  appealMessages        AppealMessage[]         @relation("AppealMessageSender")
  consents              ConsentRecord[]
  dataExports           DataExportRequest[]
  decisionReviews       DecisionReviewRequest[]

  @@index([providerId])
  @@index([email])
  @@index([passwordResetToken])
  @@index([deletedAt])
  @@map("users")
}

/// Records every consent grant or withdrawal under KDPA Art. 7 / GDPR Art. 7.
/// One row per consent action — never updated in place — so the consent history
/// is auditable end-to-end.
model ConsentRecord {
  id        String   @id @default(uuid())
  userId    String
  purpose   String // e.g. "terms_of_service", "privacy_policy", "marketing", "fraud_analytics"
  action    String // "granted" | "withdrawn"
  version   String? // policy version the user accepted
  ipAddress String?
  userAgent String?
  source    String? // "registration" | "profile" | "consent_page"
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, purpose])
  @@map("consent_records")
}

/// Tracks Right of Access / Portability requests under GDPR Art. 15 + 20.
/// Stored even after the export is downloaded so we can prove SLA compliance.
model DataExportRequest {
  id          String   @id @default(uuid())
  userId      String
  status      String   @default("completed") // "completed" | "failed"
  requestedAt DateTime @default(now())
  ipAddress   String?
  userAgent   String?
  bytes       Int?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("data_export_requests")
}

/// Records a data subject's challenge of an automated decision (fraud flag)
/// under GDPR Art. 22. A reviewer must take a human decision before closure.
model DecisionReviewRequest {
  id           String    @id @default(uuid())
  userId       String
  claimId      String?
  decisionType String // "fraud_flag" | "anomaly_score"
  reason       String
  status       String    @default("pending") // "pending" | "upheld" | "overturned"
  reviewerId   String?
  reviewerNote String?
  createdAt    DateTime  @default(now())
  resolvedAt   DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("decision_review_requests")
}

model Role {
  id              String           @id @default(uuid())
  name            String           @unique
  displayName     String?
  description     String?
  isSystem        Boolean          @default(false)
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  createdBy       String?
  updatedBy       String?
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@index([name])
  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid())
  name            String           @unique
  resource        String
  action          String
  description     String?
  isSystem        Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]

  @@index([resource])
  @@index([action])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  grantedAt    DateTime   @default(now())
  grantedBy    String?
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRole {
  id         String   @id @default(uuid())
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  assignedBy String?
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model Provider {
  id                     String                       @id @default(uuid())
  name                   String
  type                   String
  licenseNumber          String                       @unique
  contactPerson          String
  email                  String
  phone                  String
  alternatePhone         String?
  physicalAddress        String
  city                   String?
  region                 String?
  status                 String                       @default("pending")
  approvalStatus         String                       @default("pending_approval")
  approvedBy             String?
  approvedAt             DateTime?
  rejectionReason        String?
  parentProviderId       String?
  invoiceUploaderId      String?
  companyStructure       String?
  registrationNumber     String?
  kraPin                 String?
  incorporationDate      DateTime?
  numberOfPartners       Int?
  ownerName              String?
  ownerIdNumber          String?
  proofDocumentPath      String?
  proofDocumentName      String?
  isActive               Boolean                      @default(false)
  canSubmitClaims        Boolean                      @default(false)
  maxDailySubmissions    Int?                         @default(100)
  createdAt              DateTime                     @default(now())
  updatedAt              DateTime                     @updatedAt
  onboardingSubmittedAt  DateTime?
  programOfWorksText     String?
  scopeUnderstanding     String?
  yearsProvidingServices Int?
  batchSubmissions       BatchSubmission[]
  branches_rel           Branch[]
  claims                 Claim[]
  providerDocuments      Document[]                   @relation("ProviderDocuments")
  onboardingDocuments    ProviderOnboardingDocument[]
  references             ProviderReference[]
  parentProvider         Provider?                    @relation("ProviderBranches", fields: [parentProviderId], references: [id])
  branches               Provider[]                   @relation("ProviderBranches")
  users                  User[]
  aliases                ProviderAlias[]

  @@index([status])
  @@index([type])
  @@index([licenseNumber])
  @@map("providers")
}

/// Documents a provider uploads during onboarding to satisfy the procurement
/// spec (items a, b, d, f). Each row is one file tagged with its purpose.
model ProviderOnboardingDocument {
  id         String   @id @default(uuid())
  providerId String
  category   String
  fileName   String
  filePath   String
  fileSize   Int?
  mimeType   String?
  uploadedAt DateTime @default(now())
  uploadedBy String?
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@index([providerId, category])
  @@map("provider_onboarding_documents")
}

/// Reference engagements the provider is offering as proof of similar work
/// within the last five years (procurement spec item e).
model ProviderReference {
  id                  String    @id @default(uuid())
  providerId          String
  clientName          String
  contactPerson       String
  contactEmail        String?
  contactPhone        String?
  servicesProvided    String
  engagementStartDate DateTime
  engagementEndDate   DateTime?
  referenceLetterPath String?
  referenceLetterName String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  provider            Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@map("provider_references")
}

model Branch {
  id                String   @id @default(uuid())
  code              String   @unique
  name              String
  providerId        String
  region            String?
  county            String?
  address           String?
  phone             String?
  email             String?
  contactPerson     String?
  invoiceUploaderId String?
  branchManagerId   String?
  isActive          Boolean  @default(true)
  isApproved        Boolean  @default(false)
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  provider          Provider @relation(fields: [providerId], references: [id])

  @@index([providerId])
  @@index([isActive])
  @@index([isApproved])
  @@map("branches")
}

model BatchSubmission {
  id               String    @id @default(uuid())
  batchNumber      String    @unique
  providerId       String
  submissionMethod String
  totalClaims      Int       @default(0)
  totalSize        BigInt    @default(0)
  status           String    @default("uploading")
  processedClaims  Int       @default(0)
  failedClaims     Int       @default(0)
  uploadedBy       String?
  ipAddress        String?
  userAgent        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  completedAt      DateTime?
  branchId         String?
  provider         Provider  @relation(fields: [providerId], references: [id])
  claims           Claim[]

  @@index([batchNumber])
  @@index([providerId])
  @@index([branchId])
  @@index([status])
  @@index([createdAt])
  @@map("batch_submissions")
}

model Claim {
  id                    String               @id @default(uuid())
  claimNumber           String               @unique
  batchNumber           String?
  folioNumber           String?
  barcode               String               @unique
  providerId            String
  memberNumber          String?
  memberName            String?
  patientName           String?
  patientId             String?
  dateOfBirth           DateTime?
  invoiceNumber         String?
  invoiceDate           DateTime?
  invoiceAmount         Float?
  dateOfService         DateTime?
  diagnosis             String?
  treatment             String?
  procedureCodes        String[]
  status                String               @default("submitted")
  workflowStage         String               @default("initial_review")
  assignedTo            String?
  priority              String               @default("normal")
  isRejected            Boolean              @default(false)
  rejectionReason       String?
  rejectedAt            DateTime?
  rejectedBy            String?
  resubmissionCount     Int                  @default(0)
  originalClaimId       String?
  isComplete            Boolean              @default(false)
  missingDocuments      String[]
  completenessCheckedAt DateTime?
  completenessCheckedBy String?
  ocrStatus             String               @default("pending")
  ocrConfidence         Float?
  ocrProcessedAt        DateTime?
  requiresManualReview  Boolean              @default(false)
  batchId               String?
  assignmentStrategy    String?
  submittedAt           DateTime             @default(now())
  reviewedAt            DateTime?
  approvedAt            DateTime?
  paidAt                DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  createdBy             String?
  uploadedBy            String?
  notes                 String?
  internalNotes         String?
  fraudSignals          Json?                @default("[]")
  annotations           Json?                @default("[]")
  branchId              String?
  approvals             ClaimApproval[]
  emails                ClaimEmail[]
  statusHistory         ClaimStatusHistory[]
  assignedUser          User?                @relation("ClaimAssignee", fields: [assignedTo], references: [id])
  batch                 BatchSubmission?     @relation(fields: [batchId], references: [id])
  creator               User?                @relation("ClaimCreator", fields: [createdBy], references: [id])
  provider              Provider             @relation(fields: [providerId], references: [id])
  documents             Document[]
  edmsData              EdmsDocument?
  ocrData               OcrExtraction?
  appeals               Appeal[]
  slaBreached           Boolean              @default(false)
  slaBreachedAt         DateTime?
  slaDeadline           DateTime?
  eligibilityStatus     String?
  eligibilityCheckedAt  DateTime?
  eligibilityNotes      String?
  // Fraud-officer verdict relayed back to the claims officer.
  // Values: null | 'cleared' | 'confirmed'.
  fraudVerdict             String?
  fraudVerdictAt           DateTime?
  fraudVerdictBy           String?
  fraudVerdictNotes        String?
  // Final approval by the claims officer, after maker_checker + (optional) fraud review.
  claimsOfficerApprovedAt  DateTime?
  claimsOfficerApprovedBy  String?

  @@index([claimNumber])
  @@index([barcode])
  @@index([providerId])
  @@index([branchId])
  @@index([status])
  @@index([workflowStage])
  @@index([assignedTo])
  @@index([submittedAt])
  @@index([memberNumber])
  @@index([slaBreached])
  @@index([fraudVerdict])
  @@map("claims")
}

model ClaimApproval {
  id            String   @id @default(uuid())
  claimId       String
  level         String
  approvalStage String
  approvedBy    String
  decision      String
  comments      String?
  createdAt     DateTime @default(now())
  approver      User     @relation(fields: [approvedBy], references: [id])
  claim         Claim    @relation(fields: [claimId], references: [id])

  @@index([claimId])
  @@index([approvedBy])
  @@map("claim_approvals")
}

model ClaimStatusHistory {
  id         String   @id @default(uuid())
  claimId    String
  fromStatus String
  toStatus   String
  changedBy  String?
  reason     String?
  createdAt  DateTime @default(now())
  claim      Claim    @relation(fields: [claimId], references: [id])

  @@index([claimId])
  @@index([createdAt])
  @@map("claim_status_history")
}

model Document {
  id               String               @id @default(uuid())
  filename         String
  originalName     String
  mimetype         String
  size             BigInt
  path             String
  documentType     String?
  claimId          String?
  providerId       String?
  batchNumber      String?
  folioNumber      String?
  hasWatermark     Boolean              @default(false)
  pageCount        Int?
  isConverted      Boolean              @default(false)
  originalFormat   String?
  conversionStatus String?
  ocrText          String?
  ocrStatus        String               @default("pending")
  ocrConfidence    Float?
  ocrProcessedAt   DateTime?
  version          Int                  @default(1)
  parentDocumentId String?
  isLatestVersion  Boolean              @default(true)
  hasAnnotations   Boolean              @default(false)
  annotationsCount Int                  @default(0)
  metadata         Json?
  tags             String[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  uploadedBy       String?
  annotations      DocumentAnnotation[]
  versions         DocumentVersion[]
  claim            Claim?               @relation(fields: [claimId], references: [id])
  provider         Provider?            @relation("ProviderDocuments", fields: [providerId], references: [id])

  @@index([claimId])
  @@index([batchNumber])
  @@index([documentType])
  @@index([ocrStatus])
  @@index([providerId])
  @@map("documents")
}

model DocumentAnnotation {
  id            String    @id @default(uuid())
  documentId    String
  type          String
  pageNumber    Int
  x             Float
  y             Float
  width         Float?
  height        Float?
  content       String?
  color         String?
  signatureData String?
  signerName    String?
  signedAt      DateTime?
  createdBy     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  document      Document  @relation(fields: [documentId], references: [id])

  @@index([documentId])
  @@index([type])
  @@map("document_annotations")
}

model DocumentVersion {
  id                String   @id @default(uuid())
  documentId        String
  version           Int
  changeType        String
  changeDescription String?
  filePath          String
  fileSize          BigInt
  createdBy         String
  createdAt         DateTime @default(now())
  document          Document @relation(fields: [documentId], references: [id])

  @@index([documentId])
  @@map("document_versions")
}

model OcrExtraction {
  id                String    @id @default(uuid())
  claimId           String    @unique
  memberNumber      String?
  memberName        String?
  patientId         String?
  providerName      String?
  invoiceNumber     String?
  invoiceDate       DateTime?
  invoiceAmount     Float?
  patientName       String?
  dateOfService     DateTime?
  diagnosis         String?
  procedureCodes    String[]
  overallConfidence Float?
  fieldConfidences  Json?
  ocrEngine         String?
  ocrEngineVersion  String?
  templateUsed      String?
  documentType      String?
  status            String    @default("pending")
  requiresReview    Boolean   @default(false)
  reviewedBy        String?
  reviewedAt        DateTime?
  rawText           String?
  anomalyScore      Float?
  possibleFraud     Boolean   @default(false)
  anomalyReasons    String[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  processedAt       DateTime?
  claim             Claim     @relation(fields: [claimId], references: [id])

  @@index([claimId])
  @@index([status])
  @@index([requiresReview])
  @@map("ocr_extractions")
}

model OcrTemplate {
  id               String         @id @default(uuid())
  name             String         @unique
  description      String?
  documentType     String
  providerType     String?
  specificProvider String?
  fieldDefinitions Json
  accuracy         Float?
  usageCount       Int            @default(0)
  successCount     Int            @default(0)
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  createdBy        String?
  sampleFileName   String?
  sampleFilePath   String?
  zones            DocumentZone[]
  zoneHits         OcrZoneHit[]

  @@index([documentType])
  @@index([isActive])
  @@map("ocr_templates")
}

model DocumentZone {
  id              String         @id @default(uuid())
  templateId      String
  fieldName       String
  fieldLabel      String
  description     String?
  xPercent        Float
  yPercent        Float
  widthPercent    Float
  heightPercent   Float
  createdAt       DateTime       @default(now())
  searchPhrase    String?
  pageNumber      Int?
  claimField      String?
  locationContext String?
  parentZoneId    String?
  updatedAt       DateTime?
  updatedByName   String?
  parent          DocumentZone?  @relation("ZoneHierarchy", fields: [parentZoneId], references: [id])
  children        DocumentZone[] @relation("ZoneHierarchy")
  template        OcrTemplate    @relation(fields: [templateId], references: [id], onDelete: Cascade)
  hits            OcrZoneHit[]

  @@index([templateId])
  @@index([parentZoneId])
  @@map("document_zones")
}

model UnknownDocument {
  id              String    @id @default(uuid())
  filePath        String
  fileName        String
  mimeType        String    @default("application/pdf")
  guessedType     String?
  guessedProvider String?
  rawExtract      Json?
  status          String    @default("pending")
  reviewedBy      String?
  reviewedAt      DateTime?
  notes           String?
  claimId         String?
  uploadedBy      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("unknown_documents")
}

model EdmsDocument {
  id             String    @id @default(uuid())
  claimId        String    @unique
  edmsDocumentId String    @unique
  edmsBarcode    String?
  edmsIndexKey   String?
  edmsMetadata   Json?
  syncStatus     String    @default("pending")
  lastSyncAt     DateTime?
  syncError      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  claim          Claim     @relation(fields: [claimId], references: [id])

  @@index([claimId])
  @@index([edmsDocumentId])
  @@index([syncStatus])
  @@map("edms_documents")
}

model EOxegenData {
  id               String    @id @default(uuid())
  claimId          String    @unique
  memberNumber     String?
  memberName       String?
  providerName     String?
  invoiceNumber    String?
  invoiceDate      DateTime?
  invoiceAmount    Float?
  syncStatus       String    @default("pending")
  syncedAt         DateTime?
  syncError        String?
  smartClaimId     String?
  smartClaimNumber String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([claimId])
  @@index([syncStatus])
  @@index([memberNumber])
  @@map("eoxegen_data")
}

model PurgeRequest {
  id                String    @id @default(uuid())
  mergedDocumentId  String?
  sourceDocumentIds Json
  reason            String
  requestedBy       String
  status            String    @default("pending")
  reviewedBy        String?
  reviewedAt        DateTime?
  reviewNotes       String?
  executedAt        DateTime?
  purgedCount       Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status])
  @@index([requestedBy])
  @@map("purge_requests")
}

model Notification {
  id             String    @id @default(uuid())
  type           String
  channel        String
  recipientId    String?
  recipientEmail String?
  recipientPhone String?
  subject        String?
  message        String
  htmlContent    String?
  templateName   String?
  templateData   Json?
  claimId        String?
  providerId     String?
  status         String    @default("pending")
  sentAt         DateTime?
  readAt         DateTime?
  deliveredAt    DateTime?
  error          String?
  retryCount     Int       @default(0)
  maxRetries     Int       @default(3)
  priority       String    @default("normal")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  recipient      User?     @relation(fields: [recipientId], references: [id])

  @@index([recipientId])
  @@index([status])
  @@index([type])
  @@index([claimId])
  @@index([createdAt])
  @@map("notifications")
}

model NotificationTemplate {
  id           String   @id @default(uuid())
  name         String   @unique
  description  String?
  type         String
  eventType    String
  subject      String?
  bodyTemplate String
  htmlTemplate String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([eventType])
  @@index([isActive])
  @@map("notification_templates")
}

model Report {
  id          String            @id @default(uuid())
  name        String
  description String?
  type        String
  category    String?
  parameters  Json?
  filters     Json?
  groupBy     String[]
  isScheduled Boolean           @default(false)
  schedule    String?
  recipients  String[]
  format      String[]
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  createdBy   String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  isActive    Boolean           @default(true)
  executions  ReportExecution[]

  @@index([type])
  @@index([isScheduled])
  @@map("reports")
}

model ReportExecution {
  id          String    @id @default(uuid())
  reportId    String
  status      String    @default("running")
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  resultPath  String?
  resultSize  BigInt?
  rowCount    Int?
  error       String?
  executedBy  String?
  report      Report    @relation(fields: [reportId], references: [id])

  @@index([reportId])
  @@index([status])
  @@index([startedAt])
  @@map("report_executions")
}

model ActivityLog {
  id           String   @id @default(uuid())
  userId       String?
  username     String?
  userRole     String?
  action       String
  entity       String?
  entityId     String?
  ipAddress    String?
  userAgent    String?
  method       String?
  endpoint     String?
  oldValue     Json?
  newValue     Json?
  status       String
  errorMessage String?
  metadata     Json?
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
  @@map("activity_logs")
}

model ClaimEmail {
  id          String   @id @default(uuid())
  claimId     String
  sentBy      String?
  sentByName  String?
  sentTo      String
  cc          String?
  subject     String
  body        String
  htmlBody    String?
  attachments Json?    @default("[]")
  sentAt      DateTime @default(now())
  status      String   @default("sent")
  claim       Claim    @relation(fields: [claimId], references: [id])

  @@index([claimId])
  @@index([sentAt])
  @@map("claim_emails")
}

model Appeal {
  id              String           @id @default(uuid())
  claimId         String
  providerId      String
  filedBy         String
  reason          String
  additionalNotes String?
  status          String           @default("pending")
  adjudicatedBy   String?
  adjudicatedAt   DateTime?
  outcome         String?
  outcomeNotes    String?
  documents       Json?            @default("[]")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  claim           Claim            @relation(fields: [claimId], references: [id])
  filer           User             @relation("AppealFiler", fields: [filedBy], references: [id])
  adjudicator     User?            @relation("AppealAdjudicator", fields: [adjudicatedBy], references: [id])
  messages        AppealMessage[]

  @@index([claimId])
  @@index([providerId])
  @@index([status])
  @@index([filedBy])
  @@map("appeals")
}

/// Three-party appeal thread: provider, claims officer, fraud officer.
/// Each row is one message in the conversation; senderRole is captured at
/// write-time so a later role change does not rewrite history.
model AppealMessage {
  id          String   @id @default(uuid())
  appealId    String
  senderId    String
  senderRole  String
  message     String
  attachments Json     @default("[]")
  createdAt   DateTime @default(now())
  appeal      Appeal   @relation(fields: [appealId], references: [id], onDelete: Cascade)
  sender      User     @relation("AppealMessageSender", fields: [senderId], references: [id])

  @@index([appealId])
  @@index([senderId])
  @@index([createdAt])
  @@map("appeal_messages")
}

model PaymentAdvice {
  id               String    @id @default(uuid())
  adviceNumber     String    @unique
  providerId       String
  claimIds         Json
  totalAmount      Float
  status           String    @default("pending")
  generatedBy      String?
  confirmedBy      String?
  confirmedAt      DateTime?
  paymentReference String?
  paymentDate      DateTime?
  bankDetails      Json?
  notes            String?
  exportedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([providerId])
  @@index([status])
  @@index([adviceNumber])
  @@map("payment_advices")
}

model PreAuthorisation {
  id              String    @id @default(uuid())
  referenceNumber String    @unique
  providerId      String
  memberNumber    String
  memberName      String?
  treatmentType   String
  diagnosisCode   String?
  estimatedAmount Float
  requestedBy     String
  status          String    @default("pending")
  reviewedBy      String?
  reviewedAt      DateTime?
  approvedAmount  Float?
  validFrom       DateTime?
  validTo         DateTime?
  conditions      String?
  rejectionReason String?
  linkedClaimId   String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([providerId])
  @@index([memberNumber])
  @@index([status])
  @@index([referenceNumber])
  @@map("pre_authorisations")
}

model PolicyPlan {
  id              String         @id @default(uuid())
  planCode        String         @unique
  planName        String
  description     String?
  inpatientLimit  Float          @default(0)
  outpatientLimit Float          @default(0)
  dentalLimit     Float          @default(0)
  opticalLimit    Float          @default(0)
  maternityLimit  Float          @default(0)
  copayPercent    Float          @default(0)
  excessAmount    Float          @default(0)
  isActive        Boolean        @default(true)
  validFrom       DateTime?
  validTo         DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  createdBy       String?
  memberPolicies  MemberPolicy[]

  @@index([planCode])
  @@index([isActive])
  @@map("policy_plans")
}

model MemberPolicy {
  id              String     @id @default(uuid())
  memberNumber    String     @unique
  memberName      String
  planId          String
  policyStartDate DateTime
  policyEndDate   DateTime
  inpatientUsed   Float      @default(0)
  outpatientUsed  Float      @default(0)
  dentalUsed      Float      @default(0)
  opticalUsed     Float      @default(0)
  maternityUsed   Float      @default(0)
  isActive        Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  plan            PolicyPlan @relation(fields: [planId], references: [id])

  @@index([memberNumber])
  @@index([planId])
  @@index([isActive])
  @@map("member_policies")
}

model ClaimLabel {
  id               String   @id @default(uuid())
  claimId          String   @unique
  label            String // 'legitimate' | 'suspicious' | 'fraud'
  source           String // 'auto_approve' | 'auto_reject' | 'manual_review' | 'fraud_confirmed' | 'appeal_outcome'
  confidence       Float    @default(1.0)
  labelledBy       String?
  notes            String?
  featuresSnapshot Json? // captures the claim features at labelling time
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([label])
  @@index([source])
  @@index([createdAt])
  @@map("claim_labels")
}

model SystemConfig {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  dataType    String   @default("string")
  description String?
  category    String?
  isEditable  Boolean  @default(true)
  updatedBy   String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([category])
  @@map("system_config")
}

/// Normalised aliases for provider names extracted by OCR.
/// One row per alias variant → canonical provider. Allows the
/// mismatch fraud signal to survive spelling differences and
/// abbreviations without false positives.
model ProviderAlias {
  id         String   @id @default(uuid())
  providerId String
  alias      String   @unique // normalised: lowercase, no punctuation, collapsed spaces
  createdAt  DateTime @default(now())
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@map("provider_aliases")
}

/// Records every OCR zone extraction attempt — the knowledge base for
/// zone accuracy analytics. One row per zone × document extraction.
/// When a reviewer corrects a field value, wasCorrect is set to false
/// and correctedValue captures what the field should have been, creating
/// a supervised training signal for future zone refinement.
model OcrZoneHit {
  id             String        @id @default(uuid())
  zoneId         String
  templateId     String
  claimId        String?
  documentId     String?
  fieldName      String        // e.g. "invoice_amount"
  fieldLabel     String        // e.g. "Invoice Amount"
  extractedValue String?
  confidence     Float?        // 0–1
  engine         String?       // "gemini" | "anthropic" | "tesseract"
  wasCorrect     Boolean?      // null = unverified; true = confirmed correct; false = corrected
  correctedValue String?       // what the user set it to
  correctedBy    String?       // userId
  correctedAt    DateTime?
  createdAt      DateTime      @default(now())
  zone           DocumentZone  @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  template       OcrTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([zoneId])
  @@index([templateId])
  @@index([claimId])
  @@index([fieldName])
  @@index([createdAt])
  @@map("ocr_zone_hits")
}

/// Persists the calibrated per-factor weights produced by
/// AnomalyScoringService.calibrateWeights(). One row is the current
/// active model; older rows are kept for audit / rollback.
model FraudModelWeights {
  id          String   @id @default(uuid())
  weights     Json     // { factorName: weight, ... }
  sampleSize  Int
  fraudCount  Int
  legitimateCount Int
  trainedAt   DateTime @default(now())
  isActive    Boolean  @default(false)

  @@index([isActive])
  @@index([trainedAt])
  @@map("fraud_model_weights")
}
