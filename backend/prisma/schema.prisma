generator client {
  // Prisma 7: the `prisma-client` generator (no `-js`) replaces the legacy
  // `prisma-client-js`. It emits TypeScript into `output` instead of into
  // node_modules/@prisma/client. moduleFormat=cjs keeps it compatible with our
  // CommonJS NestJS build; runtime=nodejs uses the standard pg driver adapter.
  // binaryTargets is gone — v7 has no Rust query engine.
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
  runtime      = "nodejs"
}

datasource db {
  // Prisma 7 removed `url` from the schema. The connection string lives in
  // prisma.config.ts (used by Migrate/CLI) and is passed to PrismaClient at
  // runtime via the @prisma/adapter-pg driver adapter (see prisma.service.ts).
  provider = "postgresql"
}

model User {
  id                      String                   @id @default(uuid())
  email                   String                   @unique
  password                String
  name                    String
  role                    String                   @default("user")
  isActive                Boolean                  @default(true)
  requirePasswordChange   Boolean                  @default(false)
  lastLogin               DateTime?
  failedLoginAttempts     Int                      @default(0)
  lockedUntil             DateTime?
  twoFactorEnabled        Boolean                  @default(false)
  twoFactorSecret         String?
  phone                   String?
  jobTitle                String?
  department              String?
  location                String?
  timezone                String?
  language                String?
  locale                  String?                  @default("en") // C5: UI + notification locale
  bio                     String?
  avatarUrl               String?
  savedSignatures         Json?                    @default("[]")
  providerId              String?
  branchId                String?
  passwordResetToken      String?
  passwordResetExpiry     DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  createdBy               String?
  updatedBy               String?
  isOnLeave               Boolean                  @default(false)
  relieverId              String?
  reliever                User?                    @relation("UserReliever", fields: [relieverId], references: [id])
  relievingFor            User[]                   @relation("UserReliever")
  // PR1 — email OTP verification. Set when the user confirms ownership of
  // their inbox during registration. Login is blocked until this is non-null.
  emailVerifiedAt         DateTime?
  emailVerificationTokens EmailVerificationToken[]
  // PR2 — provider-admin approval workflow for users registered under a
  // provider. NULL for non-provider users (admin, claims_officer, etc.).
  // 'pending' | 'approved' | 'rejected' for provider_admin / provider_user.
  // Login is blocked unless this is null or 'approved'.
  providerApprovalStatus  String?
  providerApprovedBy      String?
  providerApprovedAt      DateTime?
  providerApprovalComment String?
  providerRejectionReason String?
  // GDPR Art. 17 — soft-erasure marker. When set, login is blocked and PII
  // is replaced with anonymised tokens but referential integrity for legally
  // retained claim records (Insurance Act 2017 s.83 — 7 year retention) is
  // preserved.
  deletedAt               DateTime?
  activityLogs            ActivityLog[]
  claimsApproved          ClaimApproval[]
  claimsAssigned          Claim[]                  @relation("ClaimAssignee")
  claimsCreated           Claim[]                  @relation("ClaimCreator")
  notifications           Notification[]
  userRoles               UserRole[]
  provider                Provider?                @relation(fields: [providerId], references: [id])
  appeals                 Appeal[]                 @relation("AppealAdjudicator")
  appealsFiled            Appeal[]                 @relation("AppealFiler")
  appealMessages          AppealMessage[]          @relation("AppealMessageSender")
  consents                ConsentRecord[]
  dataExports             DataExportRequest[]
  decisionReviews         DecisionReviewRequest[]
  scanEvents              ScanEvent[]              @relation("ScanEventUser")
  scanMeteringUpdates     ScanMeteringSettings[]   @relation("ScanMeteringSettingsUpdatedBy")
  activeStatus            String                   @default("active")
  seniorityTier           String                   @default("mid")
  notificationPrefs       NotificationPreference?
  notificationQueue       NotificationQueue[]
  // Phase 4 — nullable tenant scaffolding (see Tenant model at end of file).
  tenantId                String?
  tenant                  Tenant?                  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  casesOwned              Case[]                   @relation("CaseOwner")
  caseComments            CaseComment[]            @relation("CaseCommentAuthor")
  trustedDevices          TrustedDevice[]

  @@index([providerId])
  @@index([email])
  @@index([passwordResetToken])
  @@index([deletedAt])
  @@index([activeStatus])
  @@index([tenantId])
  @@map("users")
}

/// One-time codes used to verify a user owns the email address they
/// registered with. Codes are bcrypt-hashed at rest, expire after 10 minutes,
/// and may be attempted at most 5 times before being burned.
model EmailVerificationToken {
  id         String    @id @default(uuid())
  userId     String
  email      String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())
  // What the code authorises: "email_verification" (registration — the original
  // use), "login" (new-device second factor), or "password_change". Scoping by
  // purpose keeps the three OTP flows from consuming each other's codes.
  purpose    String    @default("email_verification")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([email])
  @@index([userId, purpose])
  @@map("email_verification_tokens")
}

/// Devices a user has confirmed via an emailed login code. A login from a
/// device NOT listed here triggers email 2FA before a token is issued; a known
/// device skips straight to the token. Used by the mobile app, which sends a
/// stable `deviceId`; the web app sends none and is unaffected.
model TrustedDevice {
  id         String   @id @default(uuid())
  userId     String
  deviceId   String
  label      String?
  lastUsedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([userId])
  @@map("trusted_devices")
}

/// Records every consent grant or withdrawal under KDPA Art. 7 / GDPR Art. 7.
/// One row per consent action — never updated in place — so the consent history
/// is auditable end-to-end.
model ConsentRecord {
  id        String   @id @default(uuid())
  userId    String
  purpose   String // e.g. "terms_of_service", "privacy_policy", "marketing", "fraud_analytics"
  action    String // "granted" | "withdrawn"
  version   String? // policy version the user accepted
  ipAddress String?
  userAgent String?
  source    String? // "registration" | "profile" | "consent_page"
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, purpose])
  @@map("consent_records")
}

/// Tracks Right of Access / Portability requests under GDPR Art. 15 + 20.
/// Stored even after the export is downloaded so we can prove SLA compliance.
model DataExportRequest {
  id          String   @id @default(uuid())
  userId      String
  status      String   @default("completed") // "completed" | "failed"
  requestedAt DateTime @default(now())
  ipAddress   String?
  userAgent   String?
  bytes       Int?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("data_export_requests")
}

/// Records a data subject's challenge of an automated decision (fraud flag)
/// under GDPR Art. 22. A reviewer must take a human decision before closure.
model DecisionReviewRequest {
  id           String    @id @default(uuid())
  userId       String
  claimId      String?
  decisionType String // "fraud_flag" | "anomaly_score"
  reason       String
  status       String    @default("pending") // "pending" | "upheld" | "overturned"
  reviewerId   String?
  reviewerNote String?
  createdAt    DateTime  @default(now())
  resolvedAt   DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("decision_review_requests")
}

model Role {
  id              String           @id @default(uuid())
  name            String           @unique
  displayName     String?
  description     String?
  isSystem        Boolean          @default(false)
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  createdBy       String?
  updatedBy       String?
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@index([name])
  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid())
  name            String           @unique
  resource        String
  action          String
  description     String?
  isSystem        Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]

  @@index([resource])
  @@index([action])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  grantedAt    DateTime   @default(now())
  grantedBy    String?
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRole {
  id         String   @id @default(uuid())
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  assignedBy String?
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model Provider {
  id                     String                       @id @default(uuid())
  name                   String
  type                   String
  licenseNumber          String                       @unique
  contactPerson          String
  email                  String
  phone                  String
  alternatePhone         String?
  physicalAddress        String
  city                   String?
  region                 String?
  // PR3.1 — ISO-3166 2-letter country code. Defaults to 'KE' for backfill
  // and for forms that don't surface a picker; the new provider wizard
  // requires the user to confirm/change it.
  country                String?                      @default("KE")
  status                 String                       @default("pending")
  approvalStatus         String                       @default("pending_approval")
  approvedBy             String?
  approvedAt             DateTime?
  rejectionReason        String?
  // PR1 — free-text comment captured by the reviewing admin at the moment of
  // approval or rejection. Stored alongside `rejectionReason` so an approval
  // can also carry a non-blocking note.
  approvalComment        String?
  parentProviderId       String?
  invoiceUploaderId      String?
  companyStructure       String?
  registrationNumber     String?
  kraPin                 String?
  incorporationDate      DateTime?
  numberOfPartners       Int?
  ownerName              String?
  ownerIdNumber          String?
  proofDocumentPath      String?
  proofDocumentName      String?
  isActive               Boolean                      @default(false)
  canSubmitClaims        Boolean                      @default(false)
  maxDailySubmissions    Int?                         @default(100)
  createdAt              DateTime                     @default(now())
  updatedAt              DateTime                     @updatedAt
  onboardingSubmittedAt  DateTime?
  // Note the provider adds when re-submitting after a returned-for-correction.
  // Shown to the reviewing admin in the onboarding packet panel.
  providerNote           String?
  programOfWorksText     String?
  scopeUnderstanding     String?
  yearsProvidingServices Int?
  batchSubmissions       BatchSubmission[]
  branches_rel           Branch[]
  claims                 Claim[]
  providerDocuments      Document[]                   @relation("ProviderDocuments")
  onboardingDocuments    ProviderOnboardingDocument[]
  references             ProviderReference[]
  parentProvider         Provider?                    @relation("ProviderBranches", fields: [parentProviderId], references: [id])
  branches               Provider[]                   @relation("ProviderBranches")
  users                  User[]
  aliases                ProviderAlias[]
  scanMeteringSettings   ScanMeteringSettings?
  scanEvents             ScanEvent[]                  @relation("ScanEventProvider")
  fraudThreshold         ProviderFraudThreshold?
  scanPacingAlerts       ScanPacingAlert[]
  tenantId               String?
  tenant                 Tenant?                      @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([type])
  @@index([licenseNumber])
  @@index([tenantId])
  @@map("providers")
}

/// Documents a provider uploads during onboarding to satisfy the procurement
/// spec (items a, b, d, f). Each row is one file tagged with its purpose.
model ProviderOnboardingDocument {
  id         String   @id @default(uuid())
  providerId String
  category   String
  fileName   String
  filePath   String
  fileSize   Int?
  mimeType   String?
  // PR1 — number of pages in the uploaded document. PDF page count is
  // extracted on upload via pdf-parse; images default to 1. Used by the
  // admin review gate to require per-page acknowledgement before approval.
  pageCount  Int?
  uploadedAt DateTime @default(now())
  uploadedBy String?
  // PR4 — per-document approval workflow.
  // status: pending | approved | rejected. Set by the reviewing admin.
  status        String    @default("pending")
  reviewedBy    String?
  reviewedAt    DateTime?
  reviewComment String?
  // PR4 — versioning. When an admin rejects a document, the provider can
  // upload a corrected file which becomes the next version. The old row
  // is kept (isLatest=false) so the audit history remains intact.
  version       Int       @default(1)
  supersedesId  String?
  supersedes    ProviderOnboardingDocument?  @relation("DocVersion", fields: [supersedesId], references: [id])
  supersededBy  ProviderOnboardingDocument[] @relation("DocVersion")
  isLatest      Boolean   @default(true)
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@index([providerId, category])
  @@index([providerId, isLatest])
  @@index([status])
  @@map("provider_onboarding_documents")
}

/// Reference engagements the provider is offering as proof of similar work
/// within the last five years (procurement spec item e).
model ProviderReference {
  id                  String    @id @default(uuid())
  providerId          String
  clientName          String
  contactPerson       String
  contactEmail        String?
  contactPhone        String?
  servicesProvided    String
  engagementStartDate DateTime
  engagementEndDate   DateTime?
  referenceLetterPath String?
  referenceLetterName String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  provider            Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@map("provider_references")
}

model Branch {
  id                String      @id @default(uuid())
  code              String      @unique
  name              String
  providerId        String
  region            String?
  county            String?
  address           String?
  phone             String?
  email             String?
  contactPerson     String?
  invoiceUploaderId String?
  branchManagerId   String?
  isActive          Boolean     @default(true)
  isApproved        Boolean     @default(false)
  notes             String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  provider          Provider    @relation(fields: [providerId], references: [id])
  scanEvents        ScanEvent[] @relation("ScanEventBranch")

  @@index([providerId])
  @@index([isActive])
  @@index([isApproved])
  @@map("branches")
}

model BatchSubmission {
  id               String    @id @default(uuid())
  batchNumber      String    @unique
  providerId       String
  submissionMethod String
  totalClaims      Int       @default(0)
  totalSize        BigInt    @default(0)
  status           String    @default("uploading")
  processedClaims  Int       @default(0)
  failedClaims     Int       @default(0)
  uploadedBy       String?
  ipAddress        String?
  userAgent        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  completedAt      DateTime?
  branchId         String?
  jobSetupId       String?
  tenantId         String?
  provider         Provider  @relation(fields: [providerId], references: [id])
  tenant           Tenant?   @relation(fields: [tenantId], references: [id])
  claims           Claim[]

  @@index([batchNumber])
  @@index([providerId])
  @@index([branchId])
  @@index([status])
  @@index([createdAt])
  @@index([tenantId])
  @@index([jobSetupId])
  @@map("batch_submissions")
}

model Claim {
  id                      String               @id @default(uuid())
  claimNumber             String               @unique
  batchNumber             String?
  folioNumber             String?
  barcode                 String               @unique
  providerId              String
  memberNumber            String?
  memberName              String?
  patientName             String?
  patientId               String?
  dateOfBirth             DateTime?
  invoiceNumber           String?
  invoiceDate             DateTime?
  invoiceAmount           Float?
  dateOfService           DateTime?
  diagnosis               String?
  treatment               String?
  procedureCodes          String[]
  status                  String               @default("submitted")
  workflowStage           String               @default("initial_review")
  assignedTo              String?
  priority                String               @default("normal")
  isRejected              Boolean              @default(false)
  rejectionReason         String?
  rejectedAt              DateTime?
  rejectedBy              String?
  resubmissionCount       Int                  @default(0)
  originalClaimId         String?
  isComplete              Boolean              @default(false)
  missingDocuments        String[]
  completenessCheckedAt   DateTime?
  completenessCheckedBy   String?
  ocrStatus               String               @default("pending")
  ocrConfidence           Float?
  ocrProcessedAt          DateTime?
  requiresManualReview    Boolean              @default(false)
  batchId                 String?
  assignmentStrategy      String?
  submittedAt             DateTime             @default(now())
  reviewedAt              DateTime?
  approvedAt              DateTime?
  paidAt                  DateTime?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  createdBy               String?
  uploadedBy              String?
  notes                   String?
  internalNotes           String?
  fraudSignals            Json?                @default("[]")
  annotations             Json?                @default("[]")
  branchId                String?
  approvals               ClaimApproval[]
  emails                  ClaimEmail[]
  statusHistory           ClaimStatusHistory[]
  assignedUser            User?                @relation("ClaimAssignee", fields: [assignedTo], references: [id])
  batch                   BatchSubmission?     @relation(fields: [batchId], references: [id])
  creator                 User?                @relation("ClaimCreator", fields: [createdBy], references: [id])
  provider                Provider             @relation(fields: [providerId], references: [id])
  documents               Document[]
  edmsData                EdmsDocument?
  ocrData                 OcrExtraction?
  lineItems               InvoiceLineItem[]
  appeals                 Appeal[]
  slaBreached             Boolean              @default(false)
  slaBreachedAt           DateTime?
  slaDeadline             DateTime?
  eligibilityStatus       String?
  eligibilityCheckedAt    DateTime?
  eligibilityNotes        String?
  // Fraud-officer verdict relayed back to the claims officer.
  // Values: null | 'cleared' | 'confirmed'.
  fraudVerdict            String?
  fraudVerdictAt          DateTime?
  fraudVerdictBy          String?
  fraudVerdictNotes       String?
  // Final approval by the claims officer, after maker_checker + (optional) fraud review.
  claimsOfficerApprovedAt DateTime?
  claimsOfficerApprovedBy String?
  // Phase 4 — nullable tenant scaffolding.
  tenantId                String?
  tenant                  Tenant?              @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  // D1: flag set when claim originates from a structured HMIS/FHIR feed
  structuredSource        Boolean              @default(false)
  // T2.3 — signal-lift labelling
  isLabelled              Boolean              @default(false)
  cases                   Case[]
  label                   ClaimLabel?

  @@index([claimNumber])
  @@index([barcode])
  @@index([providerId])
  @@index([branchId])
  @@index([status])
  @@index([workflowStage])
  @@index([assignedTo])
  @@index([submittedAt])
  @@index([memberNumber])
  @@index([slaBreached])
  @@index([fraudVerdict])
  @@index([tenantId])
  // v2-T4.2 composite hot-path indexes
  @@index([status, assignedTo, createdAt(sort: Desc)], map: "claims_status_assigned_created_idx")
  @@index([providerId, createdAt(sort: Desc)], map: "claims_provider_created_idx")
  @@map("claims")
}

model ClaimApproval {
  id            String   @id @default(uuid())
  claimId       String
  level         String
  approvalStage String
  approvedBy    String
  decision      String
  comments      String?
  createdAt     DateTime @default(now())
  approver      User     @relation(fields: [approvedBy], references: [id])
  claim         Claim    @relation(fields: [claimId], references: [id])

  @@index([claimId])
  @@index([approvedBy])
  @@map("claim_approvals")
}

model ClaimStatusHistory {
  id         String   @id @default(uuid())
  claimId    String
  fromStatus String
  toStatus   String
  changedBy  String?
  reason     String?
  createdAt  DateTime @default(now())
  claim      Claim    @relation(fields: [claimId], references: [id])

  @@index([claimId])
  @@index([createdAt])
  @@map("claim_status_history")
}

model Document {
  id               String               @id @default(uuid())
  filename         String
  originalName     String
  mimetype         String
  size             BigInt
  path             String
  documentType     String?
  claimId          String?
  providerId       String?
  batchNumber      String?
  folioNumber      String?
  hasWatermark     Boolean              @default(false)
  pageCount        Int?
  isConverted      Boolean              @default(false)
  originalFormat   String?
  conversionStatus String?
  ocrText          String?
  ocrStatus        String               @default("pending")
  ocrConfidence    Float?
  ocrProcessedAt   DateTime?
  version          Int                  @default(1)
  parentDocumentId String?
  isLatestVersion  Boolean              @default(true)
  hasAnnotations   Boolean              @default(false)
  annotationsCount Int                  @default(0)
  metadata         Json?
  tags             String[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  uploadedBy       String?
  tenantId         String?
  annotations      DocumentAnnotation[]
  versions         DocumentVersion[]
  claim            Claim?               @relation(fields: [claimId], references: [id])
  provider         Provider?            @relation("ProviderDocuments", fields: [providerId], references: [id])
  tenant           Tenant?              @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([claimId])
  @@index([batchNumber])
  @@index([documentType])
  @@index([ocrStatus])
  @@index([providerId])
  @@index([tenantId])
  @@map("documents")
}

model DocumentAnnotation {
  id            String    @id @default(uuid())
  documentId    String
  type          String
  pageNumber    Int
  x             Float
  y             Float
  width         Float?
  height        Float?
  content       String?
  color         String?
  signatureData String?
  signerName    String?
  signedAt      DateTime?
  createdBy     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  document      Document  @relation(fields: [documentId], references: [id])

  @@index([documentId])
  @@index([type])
  @@map("document_annotations")
}

model DocumentVersion {
  id                String   @id @default(uuid())
  documentId        String
  version           Int
  changeType        String
  changeDescription String?
  filePath          String
  fileSize          BigInt
  createdBy         String
  createdAt         DateTime @default(now())
  document          Document @relation(fields: [documentId], references: [id])

  @@index([documentId])
  @@map("document_versions")
}

model OcrExtraction {
  id                String    @id @default(uuid())
  claimId           String    @unique
  memberNumber      String?
  memberName        String?
  patientId         String?
  providerName      String?
  invoiceNumber     String?
  invoiceDate       DateTime?
  invoiceAmount     Float?
  patientName       String?
  dateOfService     DateTime?
  diagnosis         String?
  procedureCodes    String[]
  overallConfidence Float?
  fieldConfidences  Json?
  ocrEngine         String?
  ocrEngineVersion  String?
  templateUsed      String?
  documentType      String?
  status            String    @default("pending")
  requiresReview    Boolean   @default(false)
  reviewedBy        String?
  reviewedAt        DateTime?
  rawText           String?
  jobSetupId        String?
  customFields      Json?     @default("{}") // values for the job setup's custom index fields
  anomalyScore      Float?
  possibleFraud     Boolean   @default(false)
  anomalyReasons    String[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  processedAt       DateTime?
  tenantId          String?
  claim             Claim     @relation(fields: [claimId], references: [id])
  tenant            Tenant?   @relation(fields: [tenantId], references: [id])

  @@index([claimId])
  @@index([status])
  @@index([requiresReview])
  @@index([tenantId])
  @@map("ocr_extractions")
}

model OcrTemplate {
  id               String         @id @default(uuid())
  name             String         @unique
  description      String?
  documentType     String
  providerType     String?
  specificProvider String?
  fieldDefinitions Json
  accuracy         Float?
  usageCount       Int            @default(0)
  successCount     Int            @default(0)
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  createdBy        String?
  sampleFileName   String?
  sampleFilePath   String?
  zones            DocumentZone[]
  zoneHits         OcrZoneHit[]

  @@index([documentType])
  @@index([isActive])
  @@map("ocr_templates")
}

model DocumentZone {
  id              String         @id @default(uuid())
  templateId      String
  fieldName       String
  fieldLabel      String
  description     String?
  xPercent        Float
  yPercent        Float
  widthPercent    Float
  heightPercent   Float
  createdAt       DateTime       @default(now())
  searchPhrase    String?
  pageNumber      Int?
  claimField      String?
  locationContext String?
  parentZoneId    String?
  updatedAt       DateTime?
  updatedByName   String?
  parent          DocumentZone?  @relation("ZoneHierarchy", fields: [parentZoneId], references: [id])
