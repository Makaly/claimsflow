  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("assistant_interactions")
}

// ─── C3: Green-lane auto-triage ──────────────────────────────────────────────

/// Policy rule governing automatic approval of low-risk claims.
model GreenLaneRule {
  id                  String   @id @default(uuid())
  name                String
  minValue            Float?
  maxValue            Float?
  minScorecardQuality Float?
  minOcrConfidence    Float?
  maxFraudScore       Float?
  requireNoSignals    Boolean  @default(true)
  isActive            Boolean  @default(true)
  providerId          String? // null = applies globally
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([isActive])
  @@index([providerId])
  @@map("green_lane_rules")
}

