# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/cic_claims?schema=public"

# JWT — generate with: openssl rand -hex 64
JWT_SECRET="REPLACE_WITH_64_BYTE_RANDOM_HEX"
JWT_EXPIRES_IN="1d"

# Field-level encryption for special-category personal data (GDPR Art. 9 /
# KDPA s.44-46). Generate a 32-byte key with: openssl rand -hex 32
# This key MUST be stored in the deployment secret store and rotated per
# the controller's key-management policy. Loss of the key means loss of
# every encrypted diagnosis/treatment value — there is no recovery.
DATA_ENCRYPTION_KEY="REPLACE_WITH_32_BYTE_RANDOM_HEX"

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""   # set a strong password in production

# API
PORT=4000
API_PREFIX="api"

# Email
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-email-password"
SMTP_FROM="noreply@cic.com"

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR="./uploads"
# Structured dump folder for batch files (absolute path recommended in production)
UPLOAD_DUMP_DIR="./uploaded_files"

# Environment
NODE_ENV="production"    # set to "development" locally

# OCR
TESSERACT_LANG="eng"

# ML sidecar (FastAPI service in /ml-sidecar). When set, enables OpenCV
# preprocessing (deskew / crop-to-page / shadow removal / CLAHE / 300 DPI
# normalisation) before pages are sent to vision models. Boost accuracy
# on phone-scanned or skewed invoices by 10-20%.
ML_SIDECAR_URL="http://localhost:8000"

# Email Ingestion (OAuth 2.0 — Gmail or Outlook)
EMAIL_INGESTION_ENABLED="false"
EMAIL_PROVIDER="gmail"            # "gmail" or "outlook"
EMAIL_OAUTH_CLIENT_ID=""
EMAIL_OAUTH_CLIENT_SECRET=""
EMAIL_OAUTH_REDIRECT_URI="http://localhost:4000/api/email-ingestion/oauth/callback"
EMAIL_OAUTH_REFRESH_TOKEN=""      # populated after first OAuth flow
EMAIL_INBOX_USER=""               # e.g. claims@cic.co.ke
EMAIL_SUBJECT_FILTER="Medical Claim"
EMAIL_POLL_INTERVAL_MINUTES="15"

# EDMS (Electronic Document Management System)
EDMS_BASE_URL=""
EDMS_API_KEY=""
EDMS_DOCUMENT_TYPE="CLAIM"

# eOxegen (Payment System)
EOXEGEN_BASE_URL=""
EOXEGEN_API_KEY=""
EOXEGEN_SCHEME_CODE=""

# ─── C2: Conversational claim assistant ──────────────────────────────────────
ASSISTANT_EMBEDDING_MODEL="text-embedding-004"      # Google embedding model
ASSISTANT_LLM_MODEL="gemini-1.5-flash"              # Gemini model for answer gen
ASSISTANT_SIMILARITY_THRESHOLD="0.75"               # refuse below this cosine sim
ASSISTANT_CORPUS_DIR="./corpus"                     # Markdown/PDF source docs
GEMINI_API_KEY=""                                   # shared with OCR module

# ─── D2: Telemedicine ─────────────────────────────────────────────────────────
TELEMEDICINE_DEFAULT_ADAPTER="mock"                 # "mock"|"doctolib"|"teladoc"
TELEMEDICINE_DOCTOLIB_API_KEY=""
TELEMEDICINE_TELADOC_API_KEY=""
