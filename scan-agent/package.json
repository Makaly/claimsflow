{
  "name": "claimsflow-scan-agent",
  "version": "1.0.0",
  "description": "Local scan agent for ClaimsFlow — bridges TWAIN / SANE / WIA / ISIS scanners to the web UI over localhost",
  "main": "agent.js",
  "scripts": {
    "start": "node agent.js",
    "dev": "node agent.js",
    "build:win": "npx @yao-pkg/pkg agent.js --target node20-win-x64 --output dist/claimsflow-scan-agent.exe --no-bytecode --public --public-packages \"*\"",
    "build:linux": "npx @yao-pkg/pkg agent.js --target node20-linux-x64 --output dist/claimsflow-scan-agent-linux --no-bytecode --public",
    "build:mac": "npx @yao-pkg/pkg agent.js --target node20-macos-x64 --output dist/claimsflow-scan-agent-mac --no-bytecode --public"
  },
  "pkg": {
    "scripts": [
      "node_modules/**/*.js"
    ],
    "assets": [
      "node_modules/pdfkit/js/data/**",
      "node_modules/**/*.json",
      "node_modules/**/*.afm"
    ]
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "pdfkit": "^0.15.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^5.13.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": ["scanner", "twain", "sane", "wia", "isis", "claimsflow"],
  "license": "MIT"
}
